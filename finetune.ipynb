def compute_tiou(pred_segment, gt_segment):
    ps, pe = pred_segment
    gs, ge = gt_segment

    inter_start = max(ps, gs)
    inter_end = min(pe, ge)
    intersection = max(0, inter_end - inter_start)

    union = max(pe, ge) - min(ps, gs)
    if union <= 0:
        return 0.0

    return intersection / union


def evaluate_model(model_path, annotations):

    processor = AutoProcessor.from_pretrained(model_path)
    model = AutoModelForCausalLM.from_pretrained(model_path).to(DEVICE)
    model.eval()

    oca_correct = 0
    aa_correct = 0
    tiou_hits = 0
    tiou_total = 0

    for ann in tqdm(annotations):

        gt_op = ann["dominant_operation"]
        gt_next = ann["anticipated_next_operation"]
        gt_segment = ann["temporal_segment"]

        prompt = (
            "Analyze this video clip and output JSON with:\n"
            "1. dominant_operation\n"
            "2. anticipated_next_operation\n"
            "3. temporal_segment as [start, end]\n"
            "Respond only in JSON."
        )

        inputs = processor(text=prompt, return_tensors="pt").to(DEVICE)

        with torch.no_grad():
            output = model.generate(**inputs, max_new_tokens=256)

        decoded = processor.batch_decode(output, skip_special_tokens=True)[0]

        try:
            pred = json.loads(decoded)
        except:
            continue

        pred_op = pred.get("dominant_operation", "")
        pred_next = pred.get("anticipated_next_operation", "")
        pred_segment = pred.get("temporal_segment", [0, 0])

        # OCA
        if pred_op == gt_op:
            oca_correct += 1

        # AA@1
        if pred_next == gt_next:
            aa_correct += 1

        # tIoU@0.5
        if pred_segment != [0, 0]:
            tiou_total += 1
            tiou = compute_tiou(pred_segment, gt_segment)
            if tiou >= 0.5:
                tiou_hits += 1

    results = {
        "OCA": oca_correct / N_CLIPS,
        "tIoU@0.5": (tiou_hits / tiou_total) if tiou_total > 0 else 0.0,
        "AA@1": aa_correct / N_CLIPS
    }

    return results



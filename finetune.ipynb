import pandas as pd

ANNOTATION_PATH = "/kaggle/input/datasets/sahithyabr02/openpack-annotation/U0108/annotation/openpack-outliers/S0300.csv"

def load_annotations(path, n_clips=30):

    df = pd.read_csv(path)

    # Use mixed ISO parsing (fix for inconsistent timestamp formats)
    df["start"] = pd.to_datetime(df["start"], format="mixed")
    df["end"] = pd.to_datetime(df["end"], format="mixed")

    # Sort alphabetically by uuid
    df = df.sort_values("uuid")

    # Select first 30 rows
    df = df.head(n_clips).reset_index(drop=True)

    annotations = []

    for i in range(len(df)):

        dominant_operation = df.loc[i, "event"]

        # Next operation
        if i < len(df) - 1:
            anticipated_next_operation = df.loc[i + 1, "event"]
        else:
            anticipated_next_operation = dominant_operation

        # Convert to UNIX seconds
        start_time = df.loc[i, "start"].timestamp()
        end_time = df.loc[i, "end"].timestamp()

        annotations.append({
            "clip_id": df.loc[i, "uuid"],
            "dominant_operation": dominant_operation,
            "anticipated_next_operation": anticipated_next_operation,
            "temporal_segment": [float(start_time), float(end_time)]
        })

    return annotations



import os
import json
import torch
import pandas as pd
from datasets import Dataset
from transformers import (
    AutoTokenizer,
    AutoModelForCausalLM,
    Trainer,
    TrainingArguments,
    DataCollatorForLanguageModeling
)

DEVICE = "cuda" if torch.cuda.is_available() else "cpu"


ANNOTATION_PATH = "/kaggle/input/datasets/sahithyabr02/openpack-annotation/U0108/annotation/openpack-outliers/S0300.csv"

df = pd.read_csv(ANNOTATION_PATH)

df["start"] = pd.to_datetime(df["start"], format="mixed")
df["end"] = pd.to_datetime(df["end"], format="mixed")

df = df.sort_values("start").reset_index(drop=True)

training_examples = []

for i in range(len(df)-1):

    dominant_operation = df.loc[i, "event"]
    next_operation = df.loc[i+1, "event"]

    start_time = df.loc[i, "start"].timestamp()
    end_time = df.loc[i, "end"].timestamp()

    prompt = (
        "Given a video clip, predict:\n"
        "1. dominant_operation\n"
        "2. anticipated_next_operation\n"
        "3. temporal_segment\n"
        "Return JSON.\n\n"
    )

    target = json.dumps({
        "dominant_operation": dominant_operation,
        "anticipated_next_operation": next_operation,
        "temporal_segment": [start_time, end_time]
    })

    training_examples.append({
        "text": prompt + target
    })

dataset = Dataset.from_list(training_examples)

print("Training samples:", len(dataset))


MODEL_NAME = "gpt2"

tokenizer = AutoTokenizer.from_pretrained(MODEL_NAME)
tokenizer.pad_token = tokenizer.eos_token

model = AutoModelForCausalLM.from_pretrained(MODEL_NAME).to(DEVICE)


def tokenize_function(example):
    return tokenizer(
        example["text"],
        truncation=True,
        padding="max_length",
        max_length=256
    )

tokenized_dataset = dataset.map(tokenize_function, batched=True, remove_columns=["text"])


training_args = TrainingArguments(
    output_dir="/kaggle/working/finetuned_model",
    per_device_train_batch_size=4,
    num_train_epochs=3,
    logging_steps=50,
    save_strategy="epoch",
    fp16=torch.cuda.is_available(),
    report_to="none"
)


data_collator = DataCollatorForLanguageModeling(
    tokenizer=tokenizer,
    mlm=False
)

trainer = Trainer(
    model=model,
    args=training_args,
    train_dataset=tokenized_dataset,
    data_collator=data_collator
)


trainer.train()


model.save_pretrained("/kaggle/working/finetuned_model")
tokenizer.save_pretrained("/kaggle/working/finetuned_model")

print("Fine-tuned model saved.")


